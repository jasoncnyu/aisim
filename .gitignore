############################
# CodeIgniter 4
############################

# Writable directory (runtime data)
writable/*
!writable/.htaccess
!writable/index.html

# Environment files
.env
.env.*
!.env.example

# Cache & logs
writable/cache/*
writable/debugbar/*
writable/logs/*
writable/session/*
writable/uploads/*

############################
# Composer
############################
vendor/
composer.lock

############################
# PHP / OS
############################
.DS_Store
Thumbs.db
*.log
*.tmp
*.cache

############################
# IDE / Editor
############################
.vscode/
.idea/
*.swp
*.swo
sftp-config.json

############################
# Test / Coverage
############################
phpunit.xml
phpunit.xml.dist
coverage/

